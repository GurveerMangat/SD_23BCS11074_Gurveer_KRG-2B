        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="_vw-1SuKX0GtTiV5aObK-91" edge="1" parent="1" source="_vw-1SuKX0GtTiV5aObK-47" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="_vw-1SuKX0GtTiV5aObK-48">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="_vw-1SuKX0GtTiV5aObK-47" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="" vertex="1">
          <mxGeometry height="270" width="200" x="1760" y="1730" as="geometry" />
        </mxCell>
        <mxCell id="_vw-1SuKX0GtTiV5aObK-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="EVEN- Design an Hotstar like application&amp;nbsp;&lt;div&gt;1. User login Service&lt;br&gt;2.Subscriber Service&lt;/div&gt;&lt;div&gt;3. Movie / Tv Search Service&amp;nbsp;&lt;/div&gt;&lt;div&gt;4. Movie/ Tv show Play Service&amp;nbsp;&lt;br&gt;&lt;br&gt;Optimize the application using CDC pipeline, Highlight where proxy design pattern can be used&amp;nbsp;&lt;br&gt;Use HLS and Dash for specific live/static content playing along with manifest style file&amp;nbsp;&lt;br&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="110" width="460" x="740" y="320" as="geometry" />
        </mxCell>
        <mxCell id="_vw-1SuKX0GtTiV5aObK-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="Functional Requirements :&lt;div&gt;1. user login&amp;nbsp;&lt;/div&gt;&lt;div&gt;2. user subscribe&lt;/div&gt;&lt;div&gt;3. stream and watch movies and tv&lt;/div&gt;&lt;div&gt;4. search for movies and tv shows&lt;/div&gt;&lt;div&gt;5. should be able to do payment for subscriber model&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Non - Functional Requirements&amp;nbsp;&lt;/div&gt;&lt;div&gt;1. Latency (faster like 1.5 millon ) so needs to able to distribute and stream to all(500ms load time)&lt;/div&gt;&lt;div&gt;2. Availabiltiy &amp;gt;&amp;gt;&amp;gt; consistency should be able to watch&lt;/div&gt;&lt;div&gt;3. Change quality like 720p and 360 p&amp;nbsp;&lt;/div&gt;&lt;div&gt;4. search should be fase so less latency their as well&lt;/div&gt;&lt;div&gt;5. stability&amp;nbsp;&lt;/div&gt;&lt;div&gt;6. video should run smoothly even at low bandwidth connection so that user can stream continously&lt;/div&gt;&lt;div&gt;7. can add comments and likes&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="210" width="560" x="740" y="490" as="geometry" />
        </mxCell>
        <mxCell id="_vw-1SuKX0GtTiV5aObK-4" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="API endpoints:&amp;nbsp;&lt;div&gt;1. Post/login/user&lt;/div&gt;&lt;div&gt;{username,password}&lt;/div&gt;&lt;div&gt;2. Post/subscribe/details&lt;/div&gt;&lt;div&gt;{user meta data}&lt;/div&gt;&lt;div&gt;3. Post/subscribe/payments&lt;/div&gt;&lt;div&gt;{make payment or third party website}&lt;/div&gt;&lt;div&gt;4. get/search/name_of_file&lt;/div&gt;&lt;div&gt;{movie front display meta data and preview}&lt;/div&gt;&lt;div&gt;5. get/stream/name_of_file_id&lt;/div&gt;&lt;div&gt;6. get/user/user_id&lt;/div&gt;&lt;div&gt;{movie chunks and file}&lt;/div&gt;&lt;div&gt;7. get/movie_tv/movie_tv_id(for meta deta and like were other things about the moveis&lt;/div&gt;" vertex="1">
          <mxGeometry height="120" width="480" x="740" y="760" as="geometry" />
        </mxCell>
        <mxCell id="_vw-1SuKX0GtTiV5aObK-5" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="Databases:&lt;div&gt;1. users(userID,username,password,phone,subscribered_id)&lt;/div&gt;&lt;div&gt;2. subscribe(subscribe_id,subscribe_validity,subscribe_plan,subscribed(bool),subscribe_feautres)&lt;/div&gt;&lt;div&gt;3. movieDetails(movieID,moviename,time,date,...various other metadata as well as S3 chunk or metadata link)&lt;/div&gt;&lt;div&gt;4. Caches for various segments where we can reuse data as well as a&amp;nbsp; (CDN)&lt;/div&gt;&lt;div&gt;5. mongo database for movies and changes in them&amp;nbsp;&lt;/div&gt;" vertex="1">
          <mxGeometry height="120" width="620" x="740" y="930" as="geometry" />
        </mxCell>
